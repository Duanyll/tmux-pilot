#!/usr/bin/env python3
"""tmux-upload: Upload a local file to a remote tmux pane via base64.

Reads a local file, base64-encodes it, and sends the decode command to the
remote pane via tmux-exec.  Refuses files larger than 48 KB (64 KB encoded)
— use scp or manual chunking for large transfers.
"""

import argparse
import base64
import os
import shlex
import subprocess
import sys

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

# 48 KB raw → ~64 KB base64.  Beyond this, tmux send-keys becomes unreliable
# and transfers are slow.
MAX_RAW_BYTES = 48 * 1024

TMUX_EXEC = os.environ.get(
    "TMUX_EXEC", os.path.join(os.path.dirname(os.path.abspath(__file__)), "tmux-exec")
)


# ---------------------------------------------------------------------------
# Structured output (mirrors tmux-exec format)
# ---------------------------------------------------------------------------

def emit(target: str, status: str, hint: str | None = None) -> None:
    """Print a structured status line."""
    line = f"[tmux-upload] target={target} status: {status}"
    if hint:
        line += f" | hint: {hint}"
    print(line)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> int:
    parser = argparse.ArgumentParser(
        description="Upload a local file to a remote tmux pane via base64.",
        usage="tmux-upload -t <pane> [-s] [--force] <local-file> <remote-path>",
    )
    parser.add_argument("-t", dest="target", required=True,
                        help="target pane (e.g., 0:0.0 or %%5)")
    parser.add_argument("-s", "--sudo", action="store_true",
                        help="write via sudo tee (for protected paths)")
    parser.add_argument("--force", action="store_true",
                        help="pass --force to tmux-exec (bypass pane-changed guard)")
    parser.add_argument("local_file", metavar="local-file",
                        help="path to the local file to upload")
    parser.add_argument("remote_path", metavar="remote-path",
                        help="destination path on the remote side")

    args = parser.parse_args()

    # --- Validate local file ---
    if not os.path.isfile(args.local_file):
        emit(args.target, "error", f"local file not found: {args.local_file}")
        return 1

    raw_size = os.path.getsize(args.local_file)
    if raw_size > MAX_RAW_BYTES:
        emit(
            args.target, "rejected",
            f"file too large ({raw_size} bytes, limit {MAX_RAW_BYTES}); "
            "use scp, or split the file and upload chunks separately",
        )
        return 1

    # --- Encode ---
    with open(args.local_file, "rb") as f:
        b64 = base64.b64encode(f.read()).decode("ascii")

    # --- Build remote command ---
    # Use printf instead of echo to avoid shell interpretation of escape
    # sequences in the base64 payload (echo -e on some shells).
    # shlex.quote handles paths with single quotes, spaces, etc.
    safe_path = shlex.quote(args.remote_path)

    if args.sudo:
        cmd = f"printf '%s' '{b64}' | base64 -d | sudo tee {safe_path} > /dev/null"
    else:
        cmd = f"printf '%s' '{b64}' | base64 -d > {safe_path}"

    # --- Execute via tmux-exec ---
    exec_cmd = [TMUX_EXEC, "-t", args.target]
    if args.force:
        exec_cmd.append("--force")
    exec_cmd.append(cmd)

    result = subprocess.run(exec_cmd, capture_output=False)

    # tmux-exec prints its own structured output; we just relay the exit code.
    return result.returncode


if __name__ == "__main__":
    sys.exit(main())
